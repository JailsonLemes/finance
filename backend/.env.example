# Banco de dados
DATABASE_URL=mysql://fincouple:fincouple123@localhost:3306/fincouple

# JWT — gere com: openssl rand -base64 48
JWT_SECRET=SUBSTITUA_POR_VALOR_ALEATORIO_COM_NO_MINIMO_32_CHARS

# Servidor
PORT=3001
NODE_ENV=development

# URL do frontend (CORS + redirect pós-OAuth)
FRONTEND_URL=http://localhost:5173

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crie em https://console.cloud.google.com/apis/credentials
# Veja docs/SETUP_GOOGLE_OAUTH.md para o passo a passo completo
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
