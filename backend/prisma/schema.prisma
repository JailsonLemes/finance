generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  partnerName String?  @map("partner_name")
  darkMode    Boolean  @default(false) @map("dark_mode")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  incomes           Income[]
  expenses          Expense[]
  bills             Bill[]
  cards             Card[]
  investments       Investment[]
  goals             Goal[]
  plannings         Planning[]
  googleIntegration GoogleIntegration?

  @@map("users")
}

model Income {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  date        DateTime
  description String
  category    String
  value       Decimal  @db.Decimal(12, 2)
  type        String
  person      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("incomes")
}

model Expense {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  date          DateTime
  description   String
  category      String
  subcategory   String?
  value         Decimal   @db.Decimal(12, 2)
  person        String
  paymentMethod String    @map("payment_method")
  dueDate       DateTime? @map("due_date")
  cardId        String?   @map("card_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id])

  @@index([userId, date])
  @@map("expenses")
}

model Bill {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  description String
  value       Decimal   @db.Decimal(12, 2)
  dueDate     DateTime  @map("due_date")
  category    String
  responsible String
  status      String    @default("pending")
  paid        Boolean   @default(false)
  paidAt      DateTime? @map("paid_at")
  recurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@map("bills")
}

model Card {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  name       String
  cardLimit  Decimal  @map("card_limit") @db.Decimal(12, 2)
  closingDay Int      @map("closing_day")
  dueDay     Int      @map("due_day")
  color      String   @default("#6366f1")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  installments Installment[]

  @@map("cards")
}

model Installment {
  id                 String   @id @default(cuid())
  cardId             String   @map("card_id")
  description        String
  totalValue         Decimal  @map("total_value") @db.Decimal(12, 2)
  installmentValue   Decimal  @map("installment_value") @db.Decimal(12, 2)
  totalInstallments  Int      @map("total_installments")
  currentInstallment Int      @map("current_installment")
  date               DateTime
  createdAt          DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("installments")
}

model Investment {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String
  description   String
  investedValue Decimal  @map("invested_value") @db.Decimal(12, 2)
  currentValue  Decimal  @map("current_value") @db.Decimal(12, 2)
  profitability Decimal  @default(0) @db.Decimal(8, 4)
  date          DateTime
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("investments")
}

model Goal {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  title        String
  description  String?
  targetValue  Decimal   @map("target_value") @db.Decimal(12, 2)
  currentValue Decimal   @default(0) @map("current_value") @db.Decimal(12, 2)
  targetDate   DateTime? @map("target_date")
  category     String
  color        String    @default("#6366f1")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Planning {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  month         Int
  year          Int
  category      String
  plannedValue  Decimal  @map("planned_value") @db.Decimal(12, 2)
  realizedValue Decimal  @default(0) @map("realized_value") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year, category])
  @@map("plannings")
}

model GoogleIntegration {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  accessToken    String    @map("access_token") @db.Text
  refreshToken   String    @map("refresh_token") @db.Text
  expiresAt      DateTime  @map("expires_at")
  spreadsheetId  String?   @map("spreadsheet_id")
  spreadsheetUrl String?   @map("spreadsheet_url")
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncStatus String?   @map("last_sync_status")
  lastSyncError  String?   @map("last_sync_error") @db.Text
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}
