JWT_SECRET=troque-por-uma-string-aleatoria-longa
FRONTEND_URL=http://localhost
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/integrations/google/callback

# ─── Backup via rclone + Google Drive ─────────────────────────────────────────
# 1. Em qualquer máquina com browser: rclone config  (crie remote chamado "gdrive")
# 2. Após configurar: rclone config show gdrive
# 3. Copie o valor do campo "token" abaixo (JSON com access_token, refresh_token, etc)
RCLONE_REMOTE=gdrive
RCLONE_BACKUP_FOLDER=fincouple-backups
RCLONE_TOKEN={"access_token":"...","token_type":"Bearer","refresh_token":"...","expiry":"...","expires_in":3599}
